# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Google Places Autocomplete (for trip location field)
# https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API (New) or Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Unsplash API (for outfit inspiration images in packing)
# https://unsplash.com/oauth/applications → Create app → Copy Access Key
# NOTE: No NEXT_PUBLIC_ prefix — this stays server-side only
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Supabase service-role key (used by server-only routes: /api/delete-account,
# /api/send-invite). Project Settings → API → "service_role" key.
# Server-only. NEVER expose with NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used by /api/send-invite when building the redirect URL
# inside invite emails. No trailing slash.
# - Local dev: http://localhost:3000
# - Production (Vercel): https://tripplannerapp-lilac.vercel.app
# Set this in Vercel → Project Settings → Environment Variables for prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000